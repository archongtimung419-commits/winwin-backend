# Copy to .env and fill in real values. Never commit .env to git.

# JWT signing (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-long-random-string

# Admin dashboard credentials
ADMIN_USERNAME=AXRCNG
ADMIN_PASSWORD=change-me-on-first-login

# God Mode server-side signing keys (never expose to frontend)
GOD_MODE_SALT=GodModeSecureWinWin_2026_Salt!#
HMAC_SECRET_KEY=WinWin_HMAC_K3y_$ecure_2026!@#_N3v3rExpose

# Fast2SMS OTP (optional — leave empty to use mock OTP in dev)
FAST2SMS_API_KEY=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:8000

# SMTP credentials for verification emails
SMTP_EMAIL=winwinpro.xyz@gmail.com
SMTP_PASSWORD=replace-with-app-password

# Database
DATABASE_PATH=winwin.db
